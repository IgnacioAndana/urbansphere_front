# Copia este archivo a .env y ajusta los valores.
#   Windows:  Copy-Item .env.example .env
#   Linux/Mac: cp .env.example .env
#
# URL base del BFF (nginx -> microservicios). Debe incluir el prefijo /api.
VITE_API_BASE_URL=http://13.222.88.101/api

# (Opcional) Tamaño máximo de imágenes en subidas (MB). Debe coincidir con nginx/BFF.
# VITE_MAX_IMAGEN_MB=10

# (Opcional) Google Gemini - redactar descripcion comercial con IA en admin/proyectos.
# Obtener key en: https://aistudio.google.com/apikey
# VITE_GEMINI_API_KEY=tu_clave_de_gemini_aqui
